PORT=3000
MONGODB_URI=mongodb://localhost:27017/medibot
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASSWORD=
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# ── Google Cloud TTS ───────────────────────────────────────────────────────────
# Free tier: 1,000,000 characters/month (Neural2 & WaveNet voices)
#
# Setup (5 minutes):
#   1. Go to https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
#   2. Click "Enable"
#   3. Go to https://console.cloud.google.com/apis/credentials
#   4. Click "Create Credentials" → "API Key"
#   5. Click "Restrict Key" → restrict to "Cloud Text-to-Speech API" only
#
GOOGLE_TTS_API_KEY=YOUR_GOOGLE_TTS_API_KEY_HERE

# Voice to use (optional — defaults to en-US-Neural2-F, warm female voice)
# Other great options:
#   en-US-Neural2-C  — professional female
#   en-US-Neural2-D  — deep male
#   en-US-Neural2-A  — neutral male
#   en-US-Wavenet-F  — female (WaveNet, also excellent)
GOOGLE_TTS_VOICE=en-US-Neural2-F

# ── Auth & Security ───────────────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
JWT_SECRET=

# Frontend origin(s) for CORS — comma-separated, no trailing slashes
# For Render deployment, set this to your Render frontend URL, e.g., https://your-app-name.onrender.com
FRONTEND_URL=http://localhost:5173,http://localhost:8080

# ── VITE frontend env vars (prefix with VITE_ to expose to browser) ──────────
# Leave unset in dev to use Vite proxy (/api → port 3000). Set for production builds.
# For Render deployment, set VITE_API_URL to your Render backend URL, e.g., https://your-backend-name.onrender.com
# VITE_API_URL=http://localhost:3000
